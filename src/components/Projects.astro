---
const projects = [
  {
    name: 'Maxstream',
    type: 'CMS & API',
    company: 'Telkomsel',
    category: 'enterprise',
    description:
      'CMS and API backend for Maxstream, Telkomsel\'s video streaming platform. Built with a multi-service approach to handle high-volume content delivery.',
    tech: ['PHP', 'Node.js', 'Golang', 'MySQL'],
    url: 'https://maxstream.tv',
    isLive: true,
  },
  {
    name: 'HMS',
    type: 'Backend System',
    company: 'Enterprise',
    category: 'enterprise',
    description:
      'Multi-channel campaign blast dashboard with mobile SDK integrations and Firebase push notifications, designed for high-volume messaging delivery at scale.',
    tech: ['Golang', 'RabbitMQ', 'Firebase', 'PostgreSQL'],
    url: null,
    isLive: false,
  },
  {
    name: 'TSurvey',
    type: 'API Backend',
    company: 'Telkomsel',
    category: 'enterprise',
    description:
      'RESTful API backend for TSurvey, a digital survey and research platform by Telkomsel enabling data collection at scale.',
    tech: ['Golang', 'PostgreSQL', 'REST API'],
    url: 'https://tsurvey.id',
    isLive: true,
  },
  {
    name: 'Patricia',
    type: 'API Backend',
    company: 'Telkomsel',
    category: 'enterprise',
    description:
      'API backend development for Patricia, a Telkomsel digital product focused on user engagement and service delivery.',
    tech: ['Golang', 'PostgreSQL', 'REST API'],
    url: 'https://patricia.co.id',
    isLive: true,
  },
  {
    name: 'DigiHub',
    type: 'CMS',
    company: 'Telkomsel',
    category: 'enterprise',
    description:
      'Content management system for Telkomsel\'s digital hub portal, managing content distribution and publication workflows across digital channels.',
    tech: ['PHP', 'MySQL', 'REST API'],
    url: 'https://digihub.telkomsel.co.id',
    isLive: true,
  },
  {
    name: 'Cascade',
    type: 'SaaS Analytics Platform',
    company: 'Telkomsel',
    category: 'enterprise',
    description:
      'Backend for Cascade, a telco big data analytics platform by Telkomsel that enables businesses to leverage telecom data for competitive insights, customizable dashboards, and strategic decision-making.',
    tech: ['Golang', 'PostgreSQL', 'REST API'],
    url: 'https://cascade.telkomsel.com',
    isLive: true,
  },
  {
    name: 'Senayan City',
    type: 'Mall Website & CRM',
    company: 'Freelance',
    category: 'freelance',
    description:
      'Developed the official mall website for Senayan City with CRM integration, enabling tenant management, event promotions, and customer engagement features.',
    tech: ['PHP', 'MySQL'],
    url: 'https://senayancity.com',
    isLive: true,
  },
  {
    name: 'Kota Kasablanka',
    type: 'Mall Website',
    company: 'Freelance',
    category: 'freelance',
    description:
      'Built the official website for Kota Kasablanka mall, covering tenant directory, promotions, events, and visitor information.',
    tech: ['PHP', 'MySQL'],
    url: 'https://www.kotakasablanka.co.id',
    isLive: true,
  },
  {
    name: 'Soechi Group Recruitment Portal',
    type: 'Recruitment System',
    company: 'Freelance',
    category: 'freelance',
    description:
      'Developed a crew recruitment portal for Soechi Group, a shipping company, enabling online job applications, candidate tracking, and recruitment workflow management.',
    tech: ['PHP', 'MySQL'],
    url: 'https://career.soechigroup.com',
    isLive: true,
  },
  {
    name: 'Garuda Pariwisata',
    type: 'Travel Agency Website',
    company: 'Freelance',
    category: 'freelance',
    description:
      'Built the company website for Garuda Pariwisata, a travel agency specializing in Labuan Bajo trips, showcasing tour packages and facilitating bookings.',
    tech: ['WordPress'],
    url: 'https://garudapariwisata.com',
    isLive: true,
  },
  {
    name: 'MTs Nurul Islam Kota Kediri',
    type: 'School Website',
    company: 'Freelance',
    category: 'freelance',
    description:
      'Developed the official website for MTs Nurul Islam Kota Kediri, covering school profile, academic information, news, and announcements for students and parents.',
    tech: ['WordPress'],
    url: 'https://mtsnurulislamkotakediri.sch.id',
    isLive: true,
  },
];
---

<section id="projects" class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-10">
      <p class="text-cyan-400 text-sm font-semibold tracking-widest uppercase mb-3">Work</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Selected Projects</h2>
      <p class="text-zinc-400 mt-4 max-w-xl mx-auto text-sm leading-relaxed">
        Enterprise systems and freelance projects — from Telkomsel-scale backends
        to client websites and custom business tools.
      </p>
    </div>

    <!-- Filter Tabs -->
    <div class="flex justify-center mb-10">
      <div class="inline-flex bg-zinc-800/50 border border-zinc-700/50 rounded-xl p-1 gap-1">
        <button
          data-filter="all"
          class="filter-btn active-filter px-5 py-2 rounded-lg text-sm font-medium transition-all duration-200"
        >
          All <span class="ml-1.5 text-xs opacity-60">{projects.length}</span>
        </button>
        <button
          data-filter="enterprise"
          class="filter-btn px-5 py-2 rounded-lg text-sm font-medium transition-all duration-200"
        >
          Enterprise <span class="ml-1.5 text-xs opacity-60">{projects.filter(p => p.category === 'enterprise').length}</span>
        </button>
        <button
          data-filter="freelance"
          class="filter-btn px-5 py-2 rounded-lg text-sm font-medium transition-all duration-200"
        >
          Freelance <span class="ml-1.5 text-xs opacity-60">{projects.filter(p => p.category === 'freelance').length}</span>
        </button>
      </div>
    </div>

    <!-- Project Grid -->
    <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map(project => (
        <div
          class="project-card group bg-zinc-800/40 border border-zinc-700/50 rounded-xl p-6 flex flex-col hover:border-zinc-600 hover:bg-zinc-800/60 transition-all duration-200"
          data-category={project.category}
        >
          <!-- Header -->
          <div class="flex items-start justify-between mb-4">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium border ${project.isLive ? 'bg-green-400/10 text-green-400 border-green-400/20' : 'bg-zinc-700/50 text-zinc-400 border-zinc-600/50'}`}>
                  {project.isLive ? '● Live' : '⬤ Internal'}
                </span>
                <span class="text-xs text-zinc-500">{project.type}</span>
              </div>
              <h3 class="text-white font-semibold text-lg group-hover:text-cyan-400 transition-colors">
                {project.name}
              </h3>
              <p class="text-zinc-500 text-xs mt-0.5">{project.company}</p>
            </div>
            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-zinc-600 hover:text-cyan-400 transition-colors shrink-0 ml-3 mt-1"
                aria-label={`Visit ${project.name}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>

          <!-- Description -->
          <p class="text-zinc-400 text-sm leading-relaxed flex-1 mb-4">
            {project.description}
          </p>

          <!-- Tech Stack -->
          <div class="flex flex-wrap gap-1.5 pt-3 border-t border-zinc-700/50">
            {project.tech.map(t => (
              <span class="text-xs bg-zinc-700/50 text-zinc-300 px-2 py-0.5 rounded border border-zinc-600/50 font-medium">
                {t}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-projects" class="hidden text-center py-16 text-zinc-500">
      No projects found.
    </div>

  </div>
</section>

<style>
  .filter-btn {
    color: theme('colors.zinc.400');
  }
  .filter-btn:hover {
    color: theme('colors.zinc.200');
    background-color: theme('colors.zinc.700 / 50%');
  }
  .active-filter {
    background-color: theme('colors.cyan.400');
    color: theme('colors.zinc.950');
  }
  .active-filter:hover {
    background-color: theme('colors.cyan.300');
    color: theme('colors.zinc.950');
  }

  .project-card {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .project-card.hidden {
    display: none;
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');
  const noProjects = document.getElementById('no-projects');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      // Update active tab
      filterBtns.forEach(b => b.classList.remove('active-filter'));
      btn.classList.add('active-filter');

      // Filter cards
      let visibleCount = 0;
      cards.forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.classList.toggle('hidden', !match);
        if (match) visibleCount++;
      });

      noProjects?.classList.toggle('hidden', visibleCount > 0);
    });
  });
</script>
