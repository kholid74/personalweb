---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-800/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <a href="#" class="text-xl font-bold text-white tracking-tight">
        kholid<span class="text-cyan-400">.</span>
      </a>

      <nav class="hidden md:flex items-center gap-7">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-zinc-400 hover:text-white text-sm font-medium transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <a
        href="#contact"
        class="hidden md:inline-flex items-center bg-cyan-400 text-zinc-950 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-cyan-300 transition-colors duration-200"
      >
        Hire Me
      </a>

      <button
        id="menu-btn"
        class="md:hidden text-zinc-400 hover:text-white p-2 rounded-lg hover:bg-zinc-800 transition-colors"
        aria-label="Toggle menu"
      >
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav id="mobile-menu" class="hidden md:hidden border-t border-zinc-800/50 py-4">
      <div class="flex flex-col gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-zinc-400 hover:text-white text-sm font-medium transition-colors py-2 px-2 rounded-lg hover:bg-zinc-800/50 mobile-nav-link"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#contact"
          class="mt-3 flex items-center justify-center bg-cyan-400 text-zinc-950 px-4 py-2.5 rounded-lg text-sm font-semibold hover:bg-cyan-300 transition-colors mobile-nav-link"
        >
          Hire Me
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
