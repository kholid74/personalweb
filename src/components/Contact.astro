---
---

<section id="contact" class="py-24 bg-zinc-900/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-cyan-400 text-sm font-semibold tracking-widest uppercase mb-3">Contact</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Let's Work Together</h2>
      <p class="text-zinc-400 mt-4 max-w-xl mx-auto text-sm leading-relaxed">
        Have a project in mind? I'm open for freelance work and always happy
        to discuss new opportunities.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

      <!-- Form (3/5) -->
      <div class="lg:col-span-3">
        <form
          id="contact-form"
          action="https://formspree.io/f/xjgaynzn"
          method="POST"
          class="space-y-5"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-zinc-400 text-sm mb-2">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="John Doe"
                class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-3 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-cyan-400 transition-colors"
              />
            </div>
            <div>
              <label for="email" class="block text-zinc-400 text-sm mb-2">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="john@example.com"
                class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-3 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-cyan-400 transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="subject" class="block text-zinc-400 text-sm mb-2">Subject</label>
            <input
              type="text"
              id="subject"
              name="subject"
              required
              placeholder="Project Discussion"
              class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-3 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-cyan-400 transition-colors"
            />
          </div>

          <div>
            <label for="message" class="block text-zinc-400 text-sm mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Tell me about your project..."
              class="w-full bg-zinc-800/50 border border-zinc-700 rounded-lg px-4 py-3 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-cyan-400 transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-cyan-400 text-zinc-950 py-3 rounded-lg font-semibold hover:bg-cyan-300 transition-colors text-sm disabled:opacity-60 disabled:cursor-not-allowed"
          >
            Send Message
          </button>

          <p id="form-success" class="hidden text-green-400 text-sm text-center py-2">
            ✓ Message sent! I'll get back to you within 24 hours.
          </p>
          <p id="form-error" class="hidden text-red-400 text-sm text-center py-2">
            Something went wrong. Please email me directly at kholidabdillah@gmail.com
          </p>
        </form>
      </div>

      <!-- Contact Info (2/5) -->
      <div class="lg:col-span-2 flex flex-col gap-4">

        <!-- Availability -->
        <div class="bg-cyan-400/10 border border-cyan-400/20 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
            <span class="text-cyan-400 font-semibold text-sm">Available for Freelance</span>
          </div>
          <p class="text-zinc-400 text-sm leading-relaxed">
            Currently accepting new freelance projects. Typical response time within 24 hours.
          </p>
        </div>

        <!-- Contact Details -->
        <div class="bg-zinc-800/40 border border-zinc-700/50 rounded-xl p-5 space-y-4">
          <h3 class="text-white font-semibold text-sm mb-3">Get in touch via</h3>

          <a
            href="mailto:kholidabdillah@gmail.com"
            class="flex items-center gap-3 text-zinc-400 hover:text-cyan-400 transition-colors group"
          >
            <div class="w-9 h-9 rounded-lg bg-zinc-700/50 flex items-center justify-center group-hover:bg-cyan-400/10 transition-colors shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-zinc-500 mb-0.5">Email</p>
              <p class="text-sm font-medium">kholidabdillah@gmail.com</p>
            </div>
          </a>

          <div class="flex items-center gap-3 text-zinc-400">
            <div class="w-9 h-9 rounded-lg bg-zinc-700/50 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-zinc-500 mb-0.5">Location</p>
              <p class="text-sm font-medium">Jakarta, Indonesia</p>
            </div>
          </div>
        </div>

        <!-- LinkedIn CTA -->
        <a
          href="https://id.linkedin.com/in/kholid-abdillah-putra"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 border border-zinc-700 text-zinc-300 rounded-xl p-4 text-sm font-medium hover:border-zinc-500 hover:text-white transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          Connect on LinkedIn
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        successMsg?.classList.remove('hidden');
        errorMsg?.classList.add('hidden');
        form.reset();
        submitBtn.textContent = 'Message Sent ✓';
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      successMsg?.classList.add('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
