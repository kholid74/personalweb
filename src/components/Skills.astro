---
const skillGroups = [
  {
    category: 'Languages',
    color: 'text-cyan-400',
    skills: ['Golang', 'PHP', 'Node.js', 'JavaScript'],
  },
  {
    category: 'Databases',
    color: 'text-green-400',
    skills: ['PostgreSQL', 'MySQL', 'MongoDB', 'Redis', 'Elasticsearch'],
  },
  {
    category: 'Message Queue & Streaming',
    color: 'text-orange-400',
    skills: ['RabbitMQ', 'Firebase'],
  },
  {
    category: 'APIs & Protocols',
    color: 'text-purple-400',
    skills: ['REST API', 'GraphQL', 'gRPC'],
  },
  {
    category: 'Infrastructure & DevOps',
    color: 'text-blue-400',
    skills: ['Docker', 'Jenkins', 'Git'],
  },
  {
    category: 'CMS & Other',
    color: 'text-pink-400',
    skills: ['WordPress', 'WooCommerce'],
  },
];
---

<section id="skills" class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-cyan-400 text-sm font-semibold tracking-widest uppercase mb-3">Tech Stack</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white">Skills & Technologies</h2>
      <p class="text-zinc-400 mt-4 max-w-xl mx-auto text-sm">
        Technologies I've worked with across production systems serving enterprise-level traffic.
      </p>
    </div>

    <div class="space-y-10">
      {skillGroups.map(group => (
        <div>
          <div class="flex items-center gap-3 mb-4">
            <div class={`w-1 h-5 rounded-full bg-current ${group.color}`}></div>
            <h3 class={`text-sm font-semibold uppercase tracking-widest ${group.color}`}>
              {group.category}
            </h3>
          </div>
          <div class="flex flex-wrap gap-3">
            {group.skills.map(skill => (
              <div class="bg-zinc-800/60 border border-zinc-700/60 rounded-lg px-4 py-2.5 hover:border-zinc-600 hover:bg-zinc-800 transition-colors cursor-default">
                <span class="text-zinc-200 text-sm font-medium">{skill}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
