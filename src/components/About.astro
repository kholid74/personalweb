---
const stats = [
  { value: '8+', label: 'Years of Experience' },
  { value: '7+', label: 'Enterprise Projects' },
  { value: '4', label: 'Companies' },
  { value: '∞', label: 'Cups of Coffee' },
];
---

<section id="about" class="py-24 bg-zinc-900/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text -->
      <div>
        <p class="text-cyan-400 text-sm font-semibold tracking-widest uppercase mb-3">About Me</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Building backends that<br />
          <span class="text-cyan-400">scale and perform</span>
        </h2>
        <div class="space-y-4 text-zinc-400 leading-relaxed">
          <p>
            Backend Software Engineer with 8+ years of experience building scalable,
            performant, and secure web applications. I specialize in Golang, PHP, and Node.js —
            from RESTful & GraphQL APIs to third-party integrations (payment gateways, CRMs,
            external APIs) and WordPress solutions.
          </p>
          <p>
            Whether you need a system built from scratch, performance optimization, or API
            integration, I get it done with clean code and solid engineering practices.
          </p>
          <p>
            Currently based in <span class="text-zinc-200 font-medium">Jakarta, Indonesia</span> and
            open to remote freelance projects worldwide.
          </p>
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="#contact"
            class="bg-cyan-400 text-zinc-950 px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-cyan-300 transition-colors"
          >
            Let's Work Together
          </a>
          <a
            href="https://github.com/kholid74"
            target="_blank"
            rel="noopener noreferrer"
            class="border border-zinc-700 text-zinc-300 px-5 py-2.5 rounded-lg text-sm font-semibold hover:border-zinc-500 hover:text-white transition-colors"
          >
            View GitHub
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-4">
        {stats.map(stat => (
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-xl p-6 text-center hover:border-zinc-600 transition-colors">
            <div class="text-4xl font-bold text-cyan-400 mb-2">{stat.value}</div>
            <div class="text-zinc-400 text-sm">{stat.label}</div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
