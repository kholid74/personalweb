---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Kholid Abdillah Putra — Backend Software Engineer',
  description = 'Backend Software Engineer with 8+ years of experience building scalable web applications using Golang, PHP, and Node.js. Based in Jakarta, Indonesia. Open for freelance projects.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Kholid Abdillah Putra, Backend Developer, Software Engineer, Golang, PHP, Node.js, Jakarta, Freelance" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Kholid Abdillah Putra" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kholidputra.com" />
    <meta property="og:image" content="https://kholidputra.com/images/me.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@kholidputra_" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-zinc-950 text-zinc-100 font-sans">
    <slot />
  </body>
</html>
